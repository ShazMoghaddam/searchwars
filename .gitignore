# Flutter/Dart build output
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# Android local config (contains your local SDK path — never commit)
android/local.properties
# Gradle wrapper jar is auto-generated by `flutter pub get`
android/gradle/wrapper/gradle-wrapper.jar
android/.gradle/
android/key.properties        # Signing keystore config — keep this secret!
*.keystore
*.jks

# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec

# macOS metadata created when zipping on Mac
__MACOSX/
.DS_Store
**/.DS_Store

# IDE files
.idea/
.vscode/
*.iml

# Pub cache / overrides
pubspec_overrides.yaml
